---
// src/pages/index.astro — refactorizat: TOT textul vine din src/data/pages/home.json
// Model de urmat pentru restul paginilor (vezi INSTRUCTIUNI_DECAP_CMS.md §5).
import PageLayout from '../layouts/PageLayout.astro';
import PhoneButton from '../components/PhoneButton.astro';
import site from '../data/site.json';
import home from '../data/pages/home.json';

const { hero, infoCard, sections } = home;
const get = (k) => sections.find((s) => s.kind === k);
const process = get('process');
const authorities = get('authorities');
const avoid = get('avoid');
const reassure = get('reassure');
---

<PageLayout title={home.seoTitle} description={home.seoDescription}>
  <!-- HERO -->
  <section class="hero hero-panic">
    <div class="shell">
      <div class="hero-grid">
        <div class="hero-msg">
          <div class="eyebrow" style="margin-bottom:24px">{hero.eyebrow}</div>
          <h1 set:html={hero.title}></h1>
          <p class="lede">{hero.lede}</p>
          <div class="cta-row">
            <PhoneButton />
            <a href={site.secondaryCtaHref} class="btn-ghost">{site.secondaryCtaLabel}</a>
          </div>
          <div class="hero-meta">
            {hero.meta.map((m, i) => (
              <span class={i === 0 ? '' : 'hero-meta-dot'}><b>{m.strong}</b>{m.rest}</span>
            ))}
          </div>
        </div>
        <div class="hero-side">
          <div class="side-card-title">{infoCard.title}</div>
          {infoCard.rows.map((r) => (
            <div class="side-card-row"><b>{r.label}</b><span class="val">{r.value}</span></div>
          ))}
          <div class="live-strip"><span class="nav-pulse"></span><span>{infoCard.live}</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CUM FUNCTIONEAZA -->
  {process && (
    <section>
      <div class="shell">
        <div class="sect-head">
          <div>
            <div class="eyebrow" style="margin-bottom:16px">{process.eyebrow}</div>
            <h2>{process.heading}</h2>
          </div>
          <p class="sub">{process.sub}</p>
        </div>
        <div class="steps">
          {process.steps.map((s) => (
            <div class="step">
              <div class="step-num"><span>{s.num}</span><span>{s.kicker}</span></div>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- AUTORITATI -->
  {authorities && (
    <section class="section-alt">
      <div class="shell">
        <div class="sect-head">
          <div>
            <div class="eyebrow" style="margin-bottom:16px">{authorities.eyebrow}</div>
            <h2>{authorities.heading}</h2>
          </div>
          <p class="sub">{authorities.sub}</p>
        </div>
        <div class="auth-grid">
          {authorities.cards.map((c) => (
            <div class="auth-card">
              <span class="badge">{c.badge}</span>
              <h3>{c.title}</h3>
              <p>{c.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CE SA NU FACI -->
  {avoid && (
    <section>
      <div class="shell">
        <div class="sect-head">
          <div>
            <div class="eyebrow" style="margin-bottom:16px">{avoid.eyebrow}</div>
            <h2>{avoid.heading}</h2>
          </div>
          <p class="sub">{avoid.sub}</p>
        </div>
        <div class="avoid-grid">
          {avoid.items.map((it) => (
            <div class="avoid-item"><div class="avoid-icon">✕</div><div><h4>{it.title}</h4><p>{it.text}</p></div></div>
          ))}
        </div>
        <div style="margin-top:40px">
          <a href={avoid.ctaHref} class="btn-ghost">{avoid.ctaLabel}</a>
        </div>
      </div>
    </section>
  )}

  <!-- REASIGURARE -->
  {reassure && (
    <section class="section-alt">
      <div class="shell">
        <div class="reassure">
          <div>
            <h2>{reassure.heading}</h2>
            <p>{reassure.text}</p>
          </div>
          <div class="right"><PhoneButton /></div>
        </div>
      </div>
    </section>
  )}
</PageLayout>

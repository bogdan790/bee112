---
/**
 * Homepage - BEE112
 *
 * BMAD Phase 3: Home structure (6 zones)
 * Phase 9: Content Freeze ACTIVE - text is LOCKED
 *
 * Source of truth: .bmad/content/phase3-home.md
 */

import PageLayout from '../layouts/PageLayout.astro';
import CallButton from '../components/CallButton.astro';
import GeographicLimit from '../components/GeographicLimit.astro';
import FinalCTA from '../components/FinalCTA.astro';

const title = 'BEE112 – Ai găsit un roi de albine?';
const description = 'Ai găsit un roi de albine? Nu le omorî. Sună-ne. Intervenții gratuite, voluntari apicultori, București și Ilfov.';
---

<PageLayout title={title} description={description}>

  <!-- ZONA 1 – PANICĂ CONTROLATĂ -->
  <section class="hero-section">
    <div class="container">
      <h1>Ai găsit un roi de albine?</h1>
      <p class="hero-subtitle"><strong>Nu le omorî. Sună-ne.</strong></p>

      <CallButton sticky={true} />

      <p class="hero-subtext">Vorbim calm. Evaluăm situația. Trimitem un apicultor.</p>
    </div>
  </section>

  <!-- Geographic Limit Banner (Phase 7, Message #1) -->
  <GeographicLimit />

  <!-- ZONA 2 – CUM FUNCȚIONEAZĂ -->
  <section class="how-it-works-section">
    <div class="container">
      <h2>Cum funcționează BEE112</h2>
      <ol class="steps-list">
        <li>
          <strong>Suni și discutăm calm</strong>
        </li>
        <li>
          <strong>Trimitem un apicultor voluntar</strong>
        </li>
      </ol>
    </div>
  </section>

  <!-- ZONA 3 – EDUCAȚIE SCURTĂ -->
  <section class="education-section">
    <div class="container">
      <h2>Ce să NU faci dacă vezi un roi</h2>
      <ul class="dont-list">
        <li>Nu stropi cu insecticide</li>
        <li>Nu arunca cu apă</li>
        <li>Nu încerca să îl distrugi</li>
      </ul>

      <p>
        <a href="/importanta-albinelor" class="secondary-link">
          Află mai multe despre roiuri
        </a>
      </p>
    </div>
  </section>

  <!-- ZONA 4 – REASIGURARE FINALĂ -->
  <section class="reassurance-section">
    <div class="container">
      <p class="reassurance-text">
        Albinele nu sunt agresive când roiesc.
        În majoritatea cazurilor, intervenția este simplă și sigură.
      </p>

      <CallButton sticky={false} variant="secondary" />
    </div>
  </section>

  <!-- ZONA 5 – FINAL CALM (Phase 7, Message #8) -->
  <FinalCTA />

</PageLayout>

<style>
  /* Hero Section - Zona 1 */
  .hero-section {
    padding: var(--space-xl) 0;
    text-align: center;
    background-color: var(--color-bg-primary);
  }

  .hero-section h1 {
    font-size: var(--font-size-h1);
    margin-bottom: var(--space-md);
    color: var(--color-text-primary);
  }

  .hero-subtitle {
    font-size: var(--font-size-h3);
    margin-bottom: var(--space-lg);
    color: var(--color-text-primary);
  }

  .hero-subtext {
    font-size: var(--font-size-body);
    color: var(--color-text-secondary);
    margin-top: var(--space-lg);
    line-height: var(--line-height-relaxed);
  }

  /* How It Works - Zona 2 */
  .how-it-works-section {
    padding: var(--space-xl) 0;
    background-color: var(--color-bg-secondary);
  }

  .how-it-works-section h2 {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .steps-list {
    list-style: decimal;
    padding-left: var(--space-xl);
    max-width: 600px;
    margin: 0 auto;
  }

  .steps-list li {
    font-size: var(--font-size-h4);
    margin-bottom: var(--space-md);
    line-height: var(--line-height-normal);
  }

  /* Education - Zona 3 */
  .education-section {
    padding: var(--space-xl) 0;
  }

  .education-section h2 {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .dont-list {
    list-style: none;
    padding: 0;
    max-width: 600px;
    margin: 0 auto var(--space-lg);
  }

  .dont-list li {
    font-size: var(--font-size-body);
    margin-bottom: var(--space-sm);
    padding-left: var(--space-md);
    position: relative;
  }

  .dont-list li::before {
    content: '❌';
    position: absolute;
    left: 0;
  }

  .secondary-link {
    display: inline-block;
    text-align: center;
    width: 100%;
    color: var(--color-secondary);
    text-decoration: underline;
    font-weight: var(--font-weight-medium);
  }

  .secondary-link:hover {
    color: var(--color-secondary);
    text-decoration: none;
  }

  /* Reassurance - Zona 4 */
  .reassurance-section {
    padding: var(--space-xl) 0;
    background-color: var(--color-bg-secondary);
    text-align: center;
  }

  .reassurance-text {
    font-size: var(--font-size-h4);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 768px) {
    .hero-section h1 {
      font-size: 3rem;
    }

    .hero-subtitle {
      font-size: 1.75rem;
    }
  }
</style>

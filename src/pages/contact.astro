---
/**
 * Contact - BEE112
 *
 * BMAD Phase 4: Secondary pages
 * Phase 9: Content Freeze ACTIVE - text is LOCKED
 *
 * Source of truth: .bmad/content/phase4-contact.md
 */

import PageLayout from '../layouts/PageLayout.astro';
import CallButton from '../components/CallButton.astro';

const title = 'Contact – BEE112';
const description = 'Pentru situații care implică albine, apelul telefonic este cea mai rapidă și eficientă soluție. Sună la 0761 330 577.';
---

<PageLayout title={title} description={description}>

  <section class="content-section">
    <div class="container">

      <h1>Contact BEE112</h1>

      <p>
        Pentru situații care implică albine, <strong>apelul telefonic este cea mai rapidă și eficientă soluție</strong>.
      </p>

      <div class="contact-info">
        <p>📞 <strong>Telefon:</strong> <a href="tel:0761330577">0761 330 577</a></p>
        <p>⏰ <strong>Program:</strong> în funcție de disponibilitatea echipelor</p>
        <p>📍 <strong>Zona:</strong> București și împrejurimi (extindere în funcție de voluntari)</p>
      </div>

    </div>
  </section>

  <section class="content-section">
    <div class="container">

      <h2>Important</h2>

      <ul>
        <li>Nu folosim formulare pentru urgențe</li>
        <li>Detaliile se stabilesc <strong>la telefon</strong></li>
        <li>Discutăm calm și te ghidăm pas cu pas</li>
      </ul>

    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <p>👉 <strong>Ai găsit un roi de albine? Sună acum.</strong></p>
      <CallButton sticky={false} />
    </div>
  </section>

</PageLayout>

<style>
  .content-section {
    padding: var(--space-lg) 0;
  }

  .content-section:nth-child(even) {
    background-color: var(--color-bg-secondary);
  }

  .content-section h1 {
    margin-bottom: var(--space-lg);
  }

  .content-section h2 {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .content-section p {
    margin-bottom: var(--space-md);
  }

  .content-section ul {
    margin-bottom: var(--space-md);
  }

  .contact-info {
    background-color: var(--color-bg-secondary);
    padding: var(--space-lg);
    border-radius: var(--border-radius-md);
    margin: var(--space-lg) 0;
  }

  .contact-info p {
    font-size: var(--font-size-h4);
    margin-bottom: var(--space-sm);
  }

  .contact-info p:last-child {
    margin-bottom: 0;
  }

  .contact-info a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: var(--font-weight-bold);
  }

  .contact-info a:hover {
    text-decoration: underline;
  }

  .cta-section {
    padding: var(--space-xl) 0;
    text-align: center;
    background-color: var(--color-bg-tertiary);
  }
</style>

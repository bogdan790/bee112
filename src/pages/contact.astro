---
import PageLayout from '../layouts/PageLayout.astro';
import PhoneButton from '../components/PhoneButton.astro';
import data from '../data/pages/contact.json';
---
<PageLayout title={data.seoTitle} description={data.seoDescription}>
  <div class="page-fade">
    <section class="page-head">
      <div class="shell">
        <div class="eyebrow" style="margin-bottom:18px">{data.head.eyebrow}</div>
        <h1>{data.head.h1}</h1>
        <p class="lede">{data.head.lede}</p>
      </div>
    </section>

    <section>
      <div class="shell">
        <div class="contact-grid">
          <div>
            <PhoneButton />
            <p style="margin-top:18px;color:var(--ink-soft);font-size:15px;max-width:46ch">
              {data.phoneNote}
            </p>

            <h2 style="font-size:28px;margin-top:56px;margin-bottom:20px;letter-spacing:-0.02em">{data.geo.heading}</h2>
            <p style="color:var(--ink-soft);font-size:16px;line-height:1.7;max-width:52ch" set:html={data.geo.text}></p>

            <div class="callout warn" style="margin-top:28px;max-width:560px">
              <div class="ttl">{data.emergency.title}</div>
              <p set:html={data.emergency.text}></p>
            </div>
          </div>
          <div>
            <div class="contact-card">
              <div class="side-card-title">{data.contactCard.title}</div>
              {data.contactCard.rows.map((r) => (
                <div class="contact-stat"><b>{r.label}</b>{r.href ? <a href={r.href}>{r.value}</a> : <span>{r.value}</span>}</div>
              ))}
            </div>
            <div style="margin-top:20px">
              <a href={data.facebook.href} target="_blank" rel="noopener" class="btn-ghost" style="width:100%;justify-content:center">
                {data.facebook.label}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</PageLayout>

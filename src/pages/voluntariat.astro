---
import PageLayout from '../layouts/PageLayout.astro';
import PhoneButton from '../components/PhoneButton.astro';
import data from '../data/pages/voluntariat.json';
---
<PageLayout title={data.seoTitle} description={data.seoDescription}>
  <div class="page-fade">
    <section class="page-head">
      <div class="shell">
        <div class="eyebrow" style="margin-bottom:18px">{data.head.eyebrow}</div>
        <h1>{data.head.title}</h1>
        <p class="lede">{data.head.lede}</p>
      </div>
    </section>

    <section>
      <div class="shell" style="display:grid;grid-template-columns:1fr 1fr;gap:56px">
        <div class="prose">
          <h2>{data.who.heading}</h2>
          <p set:html={data.who.text}></p>

          <h2>{data.looking.heading}</h2>
          <ul>
            {data.looking.items.map((it) => (
              <li>{it}</li>
            ))}
          </ul>

          <h2>{data.irrelevant.heading}</h2>
          <ul>
            {data.irrelevant.items.map((it) => (
              <li>{it}</li>
            ))}
          </ul>

          <div class="callout">
            <div class="ttl">{data.callout.title}</div>
            <p>{data.callout.text}</p>
          </div>
          <PhoneButton />
        </div>
        <div class="contact-card">
          <h3 style="font-size:24px;margin-bottom:8px">{data.form.heading}</h3>
          <p style="color:var(--ink-soft);font-size:14px;margin-bottom:24px">{data.form.intro}</p>
          <form id="vol-form">
            <div class="field"><label>{data.form.nameLabel}</label><input type="text" placeholder={data.form.namePlaceholder} required /></div>
            <div class="field"><label>{data.form.phoneLabel}</label><input type="tel" placeholder={data.form.phonePlaceholder} required /></div>
            <div class="field"><label>{data.form.cityLabel}</label><input type="text" placeholder={data.form.cityPlaceholder} /></div>
            <div class="field">
              <label>{data.form.experienceLabel}</label>
              <select>
                {data.form.experienceOptions.map((opt) => (
                  <option>{opt}</option>
                ))}
              </select>
            </div>
            <div class="field"><label>{data.form.messageLabel}</label><textarea placeholder={data.form.messagePlaceholder} rows="4"></textarea></div>
            <button type="submit" class="btn-phone" style="padding:14px 22px;font-size:16px">
              <span class="ico" style="width:32px;height:32px">→</span>
              <span><span class="num">{data.form.submitLabel}</span></span>
            </button>
          </form>
          <div id="vol-thanks" class="callout" style="display:none;margin:0">
            <div class="ttl">{data.thanks.title}</div>
            <p>{data.thanks.text}</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</PageLayout>

<script>
  const form = document.getElementById('vol-form') as HTMLFormElement | null;
  const thanks = document.getElementById('vol-thanks') as HTMLElement | null;
  if (form && thanks) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.style.display = 'none';
      thanks.style.display = 'block';
    });
  }
</script>

<style>
  @media (max-width: 920px) {
    .shell > div[style*="grid-template-columns"] { display: block !important; }
    .contact-card { margin-top: 40px; }
  }
</style>

---
import PageLayout from '../layouts/PageLayout.astro';
import data from '../data/pages/autoritati.json';
---
<PageLayout title={data.seoTitle} description={data.seoDescription}>
  <div class="page-fade">
    <section class="page-head">
      <div class="shell">
        <div class="eyebrow" style="margin-bottom:18px">{data.head.eyebrow}</div>
        <h1>{data.head.title}</h1>
        <p class="lede">{data.head.lede}</p>
      </div>
    </section>

    <section>
      <div class="shell">
        <div class="auth-grid" style="grid-template-columns:1fr;gap:16px">
          <div class="auth-card" style="flex-direction:row;align-items:flex-start;gap:40px;padding:40px">
            <div style="flex:0 0 200px">
              <span class="badge">{data.authorities[0].badge}</span>
              <h3 style="margin-top:12px;font-size:32px" set:html={data.authorities[0].title}></h3>
            </div>
            <div style="flex:1">
              <p style="color:var(--ink-soft);font-size:17px;line-height:1.7;margin-bottom:16px">{data.authorities[0].paragraphs[0]}</p>
              <p style="color:var(--ink-soft);font-size:16px;line-height:1.65">{data.authorities[0].paragraphs[1]}</p>
            </div>
          </div>
          <div class="auth-card" style="flex-direction:row;align-items:flex-start;gap:40px;padding:40px">
            <div style="flex:0 0 200px">
              <span class="badge">{data.authorities[1].badge}</span>
              <h3 style="margin-top:12px;font-size:32px" set:html={data.authorities[1].title}></h3>
            </div>
            <div style="flex:1">
              <p style="color:var(--ink-soft);font-size:17px;line-height:1.7">{data.authorities[1].paragraphs[0]}</p>
            </div>
          </div>
          <div class="auth-card" style="flex-direction:row;align-items:flex-start;gap:40px;padding:40px">
            <div style="flex:0 0 200px">
              <span class="badge">{data.authorities[2].badge}</span>
              <h3 style="margin-top:12px;font-size:32px" set:html={data.authorities[2].title}></h3>
            </div>
            <div style="flex:1">
              <p style="color:var(--ink-soft);font-size:17px;line-height:1.7">{data.authorities[2].paragraphs[0]}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-alt">
      <div class="shell">
        <div class="callout" style="max-width:820px;margin:0 auto">
          <div class="ttl">{data.note.title}</div>
          <p>{data.note.text}</p>
        </div>
      </div>
    </section>
  </div>
</PageLayout>

<style>
  @media (max-width: 920px) {
    .auth-card[style*="flex-direction:row"] {
      flex-direction: column !important;
      gap: 20px !important;
    }
  }
</style>

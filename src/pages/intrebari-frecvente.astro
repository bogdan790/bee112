---
import PageLayout from '../layouts/PageLayout.astro';
import PhoneButton from '../components/PhoneButton.astro';
import data from '../data/pages/intrebari-frecvente.json';
---
<PageLayout title={data.seoTitle} description={data.seoDescription}>
  <div class="page-fade">
    <section class="page-head">
      <div class="shell">
        <div class="eyebrow" style="margin-bottom:18px">{data.eyebrow}</div>
        <h1>{data.heading}</h1>
        <p class="lede">{data.lede}</p>
      </div>
    </section>

    <section>
      <div class="narrow">
        <div class="faq-list">
          {data.faqItems.map((item) => (
            <details class="faq-item">
              <summary>
                <span>{item.question}</span>
                <span class="faq-chevron">+</span>
              </summary>
              <div class="faq-body" set:html={item.answer} />
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section-alt">
      <div class="shell" style="text-align:center">
        <p style="font-size:19px;color:var(--ink-soft);margin-bottom:32px;max-width:48ch;margin-left:auto;margin-right:auto">{data.ctaText}</p>
        <PhoneButton />
      </div>
    </section>
  </div>
</PageLayout>

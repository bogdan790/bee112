---
import PageLayout from '../layouts/PageLayout.astro';
import PhoneButton from '../components/PhoneButton.astro';
import data from '../data/pages/cum-functioneaza.json';
---

<PageLayout title={data.seoTitle} description={data.seoDescription}>
  <div class="page-fade">
    <section class="page-head">
      <div class="shell">
        <div class="eyebrow" style="margin-bottom:18px">{data.pageHead.eyebrow}</div>
        <h1>{data.pageHead.title}</h1>
        <p class="lede">{data.pageHead.lede}</p>
      </div>
    </section>

    <section>
      <div class="shell">
        <div class="steps">
          {data.steps.map((s) => (
            <div class="step">
              <div class="step-num"><span>{s.num}</span><span>{s.kicker}</span></div>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-alt">
      <div class="shell">
        <div class="sect-head">
          <div>
            <div class="eyebrow" style="margin-bottom:16px">{data.behind.eyebrow}</div>
            <h2>{data.behind.heading}</h2>
          </div>
          <p class="sub">{data.behind.sub}</p>
        </div>
        <div class="prose" style="max-width:820px">
          <ol>
            {data.behind.items.map((it) => (
              <li set:html={it}></li>
            ))}
          </ol>
          <div class="callout warn">
            <div class="ttl">{data.behind.callout.title}</div>
            <p>{data.behind.callout.text}</p>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="shell">
        <div class="sect-head">
          <div>
            <div class="eyebrow" style="margin-bottom:16px">{data.safety.eyebrow}</div>
            <h2>{data.safety.heading}</h2>
          </div>
        </div>
        <div class="prose">
          {data.safety.paragraphs.map((p) => (
            <p set:html={p}></p>
          ))}
        </div>
        <div style="margin-top:48px">
          <PhoneButton />
        </div>
      </div>
    </section>
  </div>
</PageLayout>

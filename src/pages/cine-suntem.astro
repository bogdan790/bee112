---
import PageLayout from '../layouts/PageLayout.astro';
import PhoneButton from '../components/PhoneButton.astro';
import data from '../data/pages/cine-suntem.json';

const { pageHead, about, summaryCard, noCharge } = data;
---

<PageLayout title={data.seoTitle} description={data.seoDescription}>
  <div class="page-fade">
    <section class="page-head">
      <div class="shell">
        <div class="eyebrow" style="margin-bottom:18px">{pageHead.eyebrow}</div>
        <h1>{pageHead.title}</h1>
        <p class="lede">{pageHead.lede}</p>
      </div>
    </section>

    <section>
      <div class="shell about-grid">
        <div class="prose">
          <h2>{about.nameOrigin.heading}</h2>
          <p set:html={about.nameOrigin.text}></p>

          <h2>{about.whatWeDo.heading}</h2>
          <ul>
            {about.whatWeDo.items.map((it) => (
              <li>{it}</li>
            ))}
          </ul>
          <p set:html={about.whatWeDo.summary}></p>

          <div class="callout">
            <div class="ttl">{about.callout.title}</div>
            <p>{about.callout.text}</p>
          </div>

          <h2>{about.people.heading}</h2>
          <p set:html={about.people.text}></p>

          <h2>{about.collaboration.heading}</h2>
          <p>{about.collaboration.text}</p>
        </div>
        <div>
          <div class="contact-card">
            <div class="side-card-title">{summaryCard.title}</div>
            {summaryCard.stats.map((s) => (
              <div class="contact-stat"><b>{s.label}</b><span>{s.value}</span></div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-alt">
      <div class="shell" style="text-align:center">
        <h2 style="font-size:clamp(28px,3.4vw,46px);max-width:22ch;margin:0 auto 24px;line-height:1.1">{noCharge.heading}</h2>
        <p style="max-width:52ch;margin:0 auto 36px;color:var(--ink-soft);font-size:17px">
          {noCharge.text}
        </p>
        <PhoneButton />
      </div>
    </section>
  </div>
</PageLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 64px;
    align-items: start;
  }
  @media (max-width: 920px) {
    .about-grid {
      display: block;
    }
    .contact-card { margin-top: 40px; }
  }
</style>

---
import PageLayout from '../layouts/PageLayout.astro';
import PhoneButton from '../components/PhoneButton.astro';
import data from '../data/pages/importanta-albinelor.json';
---
<PageLayout title={data.seoTitle} description={data.seoDescription}>
  <div class="page-fade">
    <section class="page-head">
      <div class="shell">
        <div class="eyebrow" style="margin-bottom:18px">{data.head.eyebrow}</div>
        <h1>{data.head.h1}</h1>
        <p class="lede">{data.head.lede}</p>
      </div>
    </section>

    <section style="padding-top:0">
      <div class="shell">
        <div class="stats-strip">
          {data.stats.map((s) => (
            <div class="stat"><div class="stat-num">{s.num}</div><div class="stat-lbl">{s.lbl}</div></div>
          ))}
        </div>
      </div>
    </section>

    <section>
      <div class="shell">
        <div class="prose">
          <h2>{data.notAggressive.heading}</h2>
          <p set:html={data.notAggressive.intro}></p>
          <ul>
            {data.notAggressive.list.map((li) => (
              <li>{li}</li>
            ))}
          </ul>
          <p>{data.notAggressive.outro}</p>

          <h2>{data.confusion.heading}</h2>
          <p set:html={data.confusion.text}></p>
          <div class="callout">
            <div class="ttl">{data.confusion.callout.title}</div>
            <p>{data.confusion.callout.text}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section-alt">
      <div class="shell">
        <div class="sect-head">
          <div>
            <div class="eyebrow" style="margin-bottom:16px">{data.identify.eyebrow}</div>
            <h2>{data.identify.heading}</h2>
          </div>
          <p class="sub">{data.identify.sub}</p>
        </div>
        <div class="id-grid">
          {data.identify.cards.map((c) => (
            <div class="id-card">
              <div class="photo"><img src={c.imgSrc} alt={c.imgAlt} style="width:100%;height:100%;object-fit:cover;display:block;" /></div>
              <div class="body">
                <span class={`verdict ${c.verdictClass}`}>{c.verdictLabel}</span>
                <h3 style="margin-top:10px">{c.title}</h3>
                <p>{c.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section>
      <div class="shell">
        <div class="reassure">
          <div>
            <h2>{data.reassure.heading}</h2>
            <p set:html={data.reassure.text}></p>
          </div>
          <div class="right">
            <PhoneButton />
          </div>
        </div>
      </div>
    </section>
  </div>
</PageLayout>

---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('jurnal');
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;
const luni = ['ianuarie','februarie','martie','aprilie','mai','iunie','iulie','august','septembrie','octombrie','noiembrie','decembrie'];
const fmt = (dt: Date) => `${dt.getUTCDate()} ${luni[dt.getUTCMonth()]} ${dt.getUTCFullYear()}`;
---

<PageLayout title={`${d.title} — Jurnal BEE112`} description={d.rezumat}>
  <section style="padding-bottom:0">
    <div class="shell">
      <a class="art-back" href="/jurnal">← Înapoi la Jurnal</a>
      <div class="art-head">
        {d.eticheta && <span class="tag">{d.eticheta}</span>}
        <h1>{d.title}</h1>
        <div class="jrn-meta"><span>Jurnal de teren · {d.locatie}</span><span class="dot"></span><span>{fmt(d.data)}</span></div>
        <p class="lede" style="margin-top:20px">{d.rezumat}</p>
      </div>
    </div>
  </section>

  <section style="padding-top:32px">
    <div class="shell">
      <figure class="art-figure art-hero">
        <img src={d.fotoHero} alt={d.fotoHeroAlt || d.fotoHeroCaption || d.title} />
      </figure>
      {d.fotoHeroCaption && <div class="art-cap">{d.fotoHeroCaption}</div>}

      <!-- Corpul articolului din Markdown; pozele ![]() devin <img> și deschid lightbox -->
      <div class="art-body">
        <Content />
      </div>

      {d.galerie.length > 0 && (
        <div class="art-gallery">
          <div class="eyebrow" style="margin-bottom:20px">Galerie · toate fotografiile</div>
          <div class="grid">
            {d.galerie.map((g) => (
              <div class="cell"><img src={g.imagine} alt={g.legenda || ''} /></div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Lightbox (vanilla) cu navigare ‹ › între poze -->
  <div class="lightbox" id="lightbox" hidden>
    <button class="close" id="lightbox-close" aria-label="Închide">×</button>
    <button class="nav prev" id="lightbox-prev" aria-label="Imaginea anterioară">‹</button>
    <img src="" alt="" id="lightbox-img" />
    <button class="nav next" id="lightbox-next" aria-label="Imaginea următoare">›</button>
  </div>

  <script>
    const lb = document.getElementById('lightbox') as HTMLElement;
    const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const prevBtn = document.getElementById('lightbox-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('lightbox-next') as HTMLButtonElement;
    const all = Array.from(document.querySelectorAll('.art-body img, .art-gallery img')) as HTMLImageElement[];
    // listă de poze UNICE (pozele apar și în text, și în galerie) — în ordinea apariției
    const srcs: string[] = [];
    const uniq: HTMLImageElement[] = [];
    all.forEach((el) => { if (!srcs.includes(el.src)) { srcs.push(el.src); uniq.push(el); } });
    let idx = 0;

    // ascunde săgețile dacă e o singură poză
    const multi = uniq.length > 1;
    prevBtn.hidden = !multi;
    nextBtn.hidden = !multi;

    const show = (i: number) => {
      idx = (i + uniq.length) % uniq.length;
      const el = uniq[idx];
      lbImg.src = el.currentSrc || el.src;
      lbImg.alt = el.alt || '';
    };
    const open = (i: number) => { show(i); lb.hidden = false; };
    const close = () => { lb.hidden = true; lbImg.src = ''; };
    const prev = () => show(idx - 1);
    const next = () => show(idx + 1);

    all.forEach((el) => {
      el.style.cursor = 'zoom-in';
      el.addEventListener('click', () => open(srcs.indexOf(el.src)));
    });
    prevBtn.addEventListener('click', (e) => { e.stopPropagation(); prev(); });
    nextBtn.addEventListener('click', (e) => { e.stopPropagation(); next(); });
    document.getElementById('lightbox-close')!.addEventListener('click', (e) => { e.stopPropagation(); close(); });
    // click pe fundalul întunecat închide; click pe imagine/butoane nu
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft' && multi) prev();
      else if (e.key === 'ArrowRight' && multi) next();
    });
  </script>
</PageLayout>

---
import PageLayout from '../layouts/PageLayout.astro';
import PhoneButton from '../components/PhoneButton.astro';
import data from '../data/pages/ce-sa-nu-faci.json';
---

<PageLayout title={data.seoTitle} description={data.seoDescription}>
  <div class="page-fade">
    <section class="page-head">
      <div class="shell">
        <div class="eyebrow" style="margin-bottom:18px">{data.head.eyebrow}</div>
        <h1>{data.head.title}</h1>
        <p class="lede">{data.head.lede}</p>
      </div>
    </section>

    <section>
      <div class="shell">
        <div class="avoid-grid">
          {data.avoidItems.map((it) => (
            <div class="avoid-item"><div class="avoid-icon">✕</div><div><h4>{it.title}</h4><p>{it.text}</p></div></div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-alt">
      <div class="shell">
        <div class="sect-head">
          <div>
            <div class="eyebrow" style="margin-bottom:16px">{data.instead.eyebrow}</div>
            <h2>{data.instead.heading}</h2>
          </div>
        </div>
        <div class="steps">
          {data.instead.steps.map((s) => (
            <div class="step">
              <div class="step-num"><span>{s.num}</span><span>{s.kicker}</span></div>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
          ))}
        </div>
        <div style="margin-top:56px;text-align:center">
          <PhoneButton />
          <p style="margin-top:18px;color:var(--ink-soft);font-size:14px">{data.instead.note}</p>
        </div>
      </div>
    </section>
  </div>
</PageLayout>

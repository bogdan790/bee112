---
// src/components/PhoneButton.astro
// Buton de telefon reutilizabil — citește datele din site.json.
// Folosește-l peste tot unde era butonul hardcodat (hero, reasigurare, pagini).
import site from '../data/site.json';

interface Props {
  label?: string; // suprascrie eticheta implicită, dacă vrei
}
const { label } = Astro.props;
---

<a href={`tel:${site.phoneTel}`} class="btn-phone">
  <span class="ico">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
  <span>
    <span class="lbl">{label ?? site.phoneBtnLabel}</span>
    <span class="num">{site.phone}</span>
  </span>
</a>

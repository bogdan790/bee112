---
/**
 * Footer - Site Footer
 *
 * Phase 6 (Tone): Transparency, volunteer reminder, contact
 * Phase 7 (Critical Messages): Volunteer service reminder
 *
 * Features:
 * - Quick links (same as navigation)
 * - Contact information (phone)
 * - Volunteer reminder (Phase 7 Message #3)
 * - Copyright
 *
 * Layout: Single column mobile, 2-column desktop
 */

// Phone number (consistent with CallButton)
const PHONE_NUMBER = '0761 330 577';
const PHONE_LINK = 'tel:0761330577';

// Current year for copyright
const currentYear = new Date().getFullYear();

// Quick links (same as Header navigation)
const footerLinks = [
  { href: '/cine-suntem', label: 'Cine suntem' },
  { href: '/importanta-albinelor', label: 'Importanța albinelor' },
  { href: '/intrebari-frecvente', label: 'Întrebări frecvente' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="site-footer">
  <div class="site-footer__container container">
    <!-- Quick Links Section -->
    <div class="site-footer__section">
      <h4 class="site-footer__heading">Navigare</h4>
      <ul class="site-footer__links">
        {footerLinks.map((link) => (
          <li>
            <a href={link.href} class="site-footer__link">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact & Info Section -->
    <div class="site-footer__section">
      <h4 class="site-footer__heading">Contact</h4>
      <p>
        <strong>Telefon:</strong> <a href={PHONE_LINK} class="site-footer__link">{PHONE_NUMBER}</a>
      </p>
      <p>
        <strong>Zonă:</strong> București și Ilfov
      </p>
    </div>

    <!-- Volunteer Reminder Section (Phase 7 Message #3) -->
    <div class="site-footer__section">
      <h4 class="site-footer__heading">Vrei să ajuți?</h4>
      <p>
        Suntem voluntari din Patrula Apicolă Urbană.<br />
        Dacă ești apicultor sau pasionat de protejarea albinelor, <a href={PHONE_LINK} class="site-footer__link">sună-ne</a>.
      </p>
    </div>
  </div>

  <!-- Copyright -->
  <div class="container">
    <p class="site-footer__copyright">
      © {currentYear} BEE112 – Inițiativă civică de salvare a albinelor
    </p>
  </div>
</footer>

<!--
  NO scoped styles needed - all styles in components.css
  Footer layout (single column mobile, 2-column desktop) handled by CSS
-->

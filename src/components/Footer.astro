---
// src/components/Footer.astro — refactorizat: tagline, coloane, linkuri din footer.json.
import footer from '../data/footer.json';
const currentYear = new Date().getFullYear();
const bottomRight = (footer.bottomRight || '').replace('{{year}}', String(currentYear));
---

<footer>
  <div class="shell">
    <div class="foot-grid">
      <div>
        <div style="margin-bottom:16px">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 240 75" style="height:52px;width:auto;display:block">
            <g transform="translate(0,5)">
              <path d="M 0 35 Q 45 28 95 18" stroke="#888b8d" stroke-width="12" stroke-linecap="round" fill="none"/>
              <path d="M 75 18 Q 80 5 95 5 Q 90 15 80 20 Z" fill="#5a8a3a"/>
              <path d="M 30 30 Q 25 15 15 18 Q 20 28 28 32 Z" fill="#5a8a3a"/>
              <path d="M 12 34 C 20 28, 28 32, 35 28 C 40 22, 45 20, 50 25 C 55 16, 65 14, 72 20 C 80 18, 85 24, 86 32 C 88 55, 65 70, 48 65 C 30 60, 15 45, 12 34 Z" fill="#4a2e15"/>
              <path d="M 25 45 C 35 52, 45 50, 55 45 M 35 55 C 45 60, 55 58, 65 50 M 65 30 C 72 35, 75 40, 75 45" stroke="#f4f1ea" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.8"/>
            </g>
            <text x="105" y="52" font-family="var(--font-heading,ui-sans-serif,system-ui,sans-serif)" font-size="36" font-weight="900" fill="#ffffff" letter-spacing="-0.5">BEE<tspan fill="var(--primary)">112</tspan></text>
          </svg>
        </div>
        <p style="max-width:32ch;font-size:14px;line-height:1.6">{footer.tagline}</p>
      </div>

      {footer.columns.map((col) => (
        <div>
          <h4>{col.title}</h4>
          <ul>
            {col.links.map((link) => {
              const ext = link.href.startsWith('http');
              return (
                <li>
                  {link.href
                    ? <a href={link.href} {...(ext ? { target: '_blank', rel: 'noopener' } : {})}>{link.label}</a>
                    : link.label}
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>
    <div class="foot-bottom">
      <span>{footer.bottomLeft}</span>
      <span>{bottomRight}</span>
    </div>
  </div>
</footer>
